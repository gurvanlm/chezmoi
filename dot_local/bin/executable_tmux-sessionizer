#!/usr/bin/env bash
# tmux-sessionizer — picker TUI (fzf) pour s'attacher à une session tmux
# existante ou en créer une nouvelle. Lancé au démarrage du shell WezTerm.

set -euo pipefail

# Déjà dans tmux → ne rien faire
[ -n "${TMUX:-}" ] && exit 0

sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)

# Serveur froid (aucune session). On restaure explicitement la dernière
# sauvegarde tmux-resurrect AVANT de s'attacher, plutôt que de rester seul
# dans 'main' : sinon l'autosave de continuum finit par écraser la bonne
# sauvegarde avec un instantané à une seule session (perte de sessions).
if [ -z "$sessions" ]; then
    resurrect_last="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/resurrect/last"
    plugins="${TMUX_PLUGIN_MANAGER_PATH:-$HOME/.config/tmux/plugins}"
    restore_script="$plugins/tmux-resurrect/scripts/restore.sh"

    if [ -e "$resurrect_last" ] && [ -x "$restore_script" ]; then
        tmux new-session -d -s _restore          # démarre le serveur (charge la config)
        tmux run-shell "$restore_script" || true  # restauration synchrone des sessions
        if [ "$(tmux list-sessions 2>/dev/null | grep -cv '^_restore:' || true)" -gt 0 ]; then
            tmux kill-session -t _restore 2>/dev/null || true   # sessions restaurées : on jette le bootstrap
        else
            tmux rename-session -t _restore main 2>/dev/null || true  # rien à restaurer
        fi
        exec tmux attach
    fi

    # Aucune sauvegarde disponible → session par défaut
    exec tmux new-session -s main
fi

new_label='  + new session'
choice=$(printf '%s\n%s' "$sessions" "$new_label" \
    | fzf --reverse --height=40% --prompt='tmux ❯ ' \
          --header='Choisir une session (Échap = shell simple)')

# Échap / annulation → on reste sur un shell normal
[ -z "${choice:-}" ] && exit 0

if [ "$choice" = "$new_label" ]; then
    read -rp 'Nom de la session (vide = auto) : ' name
    if [ -n "$name" ]; then
        exec tmux new-session -s "$name"
    else
        exec tmux new-session
    fi
else
    exec tmux attach-session -t "$choice"
fi
