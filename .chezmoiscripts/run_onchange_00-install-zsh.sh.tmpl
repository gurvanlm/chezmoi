{{- if .installZsh -}}
#!/bin/bash
set -eo pipefail

if ! command -v zsh &> /dev/null; then
    echo "Installing zsh..."
    sudo apt-get update
    sudo apt-get install -y zsh
fi

ZSH_PATH=$(command -v zsh || true)
if [ -n "$ZSH_PATH" ] && [ "$SHELL" != "$ZSH_PATH" ]; then
    echo "Setting zsh as default shell..."
    sudo chsh -s "$ZSH_PATH" "{{ .chezmoi.username }}" 2>/dev/null || {
        echo "chsh failed (user not in /etc/passwd?). Add 'exec zsh' to your .bashrc or change shell manually."
    }
else
    echo "zsh is already the default shell."
fi
{{- end }}
