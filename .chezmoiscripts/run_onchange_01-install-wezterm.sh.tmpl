{{- if .installWezterm -}}
#!/bin/bash
set -euo pipefail

if ! command -v wezterm &> /dev/null; then
    echo "Installing wezterm..."

    # Try APT repository first (works on Debian 13+)
    apt_ok=false
    if [ ! -f /usr/share/keyrings/wezterm-fury.gpg ]; then
        curl -fsSL https://apt.fury.io/wez/gpg.key | sudo gpg --yes --dearmor -o /usr/share/keyrings/wezterm-fury.gpg
    fi

    echo "deb [signed-by=/usr/share/keyrings/wezterm-fury.gpg] https://apt.fury.io/wez/ * *" \
        | sudo tee /etc/apt/sources.list.d/wezterm.list > /dev/null

    sudo apt-get update -qq
    if sudo apt-get install -y wezterm-nightly 2>/dev/null; then
        apt_ok=true
    fi

    # Fallback: AppImage (for older Debian/Ubuntu with incompatible libs)
    if [ "$apt_ok" = false ]; then
        echo "APT install failed, falling back to AppImage..."
        sudo rm -f /etc/apt/sources.list.d/wezterm.list
        mkdir -p ~/.local/bin
        url=$(curl -fsSL "https://api.github.com/repos/wez/wezterm/releases/latest" \
            | grep "browser_download_url.*AppImage" | head -1 | cut -d'"' -f4)
        curl -fsSL "$url" -o ~/.local/bin/wezterm
        chmod +x ~/.local/bin/wezterm
        echo "WezTerm AppImage installed."

        # Create .desktop file for AppImage
        mkdir -p ~/.local/share/applications
        cat > ~/.local/share/applications/org.wezfurlong.wezterm.desktop <<DESKTOP
[Desktop Entry]
Name=WezTerm
Comment=Wez's Terminal Emulator
Exec=$HOME/.local/bin/wezterm
Terminal=false
Type=Application
Categories=System;TerminalEmulator;
StartupNotify=true
StartupWMClass=org.wezfurlong.wezterm
DESKTOP
        update-desktop-database ~/.local/share/applications 2>/dev/null || true
    fi
fi

# Set wezterm as default terminal emulator
export PATH="$HOME/.local/bin:$PATH"
WEZTERM_PATH=$(command -v wezterm 2>/dev/null || true)
if [ -n "$WEZTERM_PATH" ] && command -v update-alternatives &> /dev/null; then
    WEZTERM_PATH=$(readlink -f "$WEZTERM_PATH")
    current=$(update-alternatives --query x-terminal-emulator 2>/dev/null | grep "^Value:" | awk '{print $2}' || true)
    if [ "$current" != "$WEZTERM_PATH" ]; then
        echo "Setting wezterm as default terminal..."
        sudo update-alternatives --install /usr/bin/x-terminal-emulator x-terminal-emulator "$WEZTERM_PATH" 50
        sudo update-alternatives --set x-terminal-emulator "$WEZTERM_PATH"
    else
        echo "wezterm is already the default terminal."
    fi
fi

# Set wezterm as default terminal in GNOME
if command -v gsettings &> /dev/null && gsettings list-schemas 2>/dev/null | grep -q org.gnome.desktop.default-applications.terminal; then
    current_gnome=$(gsettings get org.gnome.desktop.default-applications.terminal exec 2>/dev/null || true)
    if [ "$current_gnome" != "'wezterm'" ]; then
        echo "Setting wezterm as GNOME default terminal..."
        gsettings set org.gnome.desktop.default-applications.terminal exec wezterm
        gsettings set org.gnome.desktop.default-applications.terminal exec-arg ''
    else
        echo "wezterm is already the GNOME default terminal."
    fi
fi

# Set wezterm as default terminal for xdg-terminal-exec (used by Nautilus 48+)
if ! command -v xdg-terminal-exec &> /dev/null; then
    sudo apt-get install -y xdg-terminal-exec 2>/dev/null || true
fi
mkdir -p ~/.config
if [ ! -f ~/.config/xdg-terminals.list ] || ! grep -q 'org.wezfurlong.wezterm.desktop' ~/.config/xdg-terminals.list; then
    echo "Setting wezterm as xdg-terminal-exec default..."
    echo 'org.wezfurlong.wezterm.desktop' > ~/.config/xdg-terminals.list
fi

# Add wezterm to GNOME dock favorites
if command -v gsettings &> /dev/null && gsettings list-schemas 2>/dev/null | grep -q org.gnome.shell; then
    favorites=$(gsettings get org.gnome.shell favorite-apps)
    if ! echo "$favorites" | grep -q 'org.wezfurlong.wezterm.desktop'; then
        echo "Adding wezterm to GNOME dock..."
        new_favorites=$(echo "$favorites" | sed "s/]/, 'org.wezfurlong.wezterm.desktop']/")
        gsettings set org.gnome.shell favorite-apps "$new_favorites"
    else
        echo "wezterm is already in GNOME dock."
    fi
fi

# Bind Ctrl+Alt+T to launch wezterm
if command -v gsettings &> /dev/null && gsettings list-schemas 2>/dev/null | grep -q org.gnome.settings-daemon.plugins.media-keys; then
    keybinding_path="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/wezterm/"
    current=$(gsettings get org.gnome.settings-daemon.plugins.media-keys custom-keybindings)
    if ! echo "$current" | grep -q "$keybinding_path"; then
        echo "Adding Ctrl+Alt+T shortcut for wezterm..."
        if [ "$current" = "@as []" ]; then
            new="['$keybinding_path']"
        else
            new=$(echo "$current" | sed "s|]|, '$keybinding_path']|")
        fi
        gsettings set org.gnome.settings-daemon.plugins.media-keys custom-keybindings "$new"
    fi
    gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:$keybinding_path name 'WezTerm'
    gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:$keybinding_path command 'wezterm'
    gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:$keybinding_path binding '<Control><Alt>t'
fi

# Install JetBrains Mono Nerd Font
if ! fc-list | grep -qi "JetBrainsMono Nerd Font"; then
    echo "Installing JetBrains Mono Nerd Font..."
    mkdir -p ~/.local/share/fonts
    curl -fsSL "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.tar.xz" \
        | tar xJ -C ~/.local/share/fonts
    fc-cache -f
    echo "JetBrains Mono Nerd Font installed."
else
    echo "JetBrains Mono Nerd Font is already installed."
fi
{{- end }}
