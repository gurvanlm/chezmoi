{{- if .installDashToPanel -}}
#!/bin/bash
set -eo pipefail

EXT_UUID="dash-to-panel@jderose9.github.com"

# Install extension if not present
if ! gnome-extensions show "$EXT_UUID" &> /dev/null; then
    echo "Installing Dash to Panel..."

    # Get GNOME Shell version
    SHELL_VERSION=$(gnome-shell --version | grep -oP '\d+')

    # Download from extensions.gnome.org
    tmpdir=$(mktemp -d)
    curl -fsSL "https://extensions.gnome.org/extension-data/dash-to-paneljderose9.github.com.v72.shell-extension.zip" \
        -o "$tmpdir/dash-to-panel.zip" 2>/dev/null || {
        # Fallback: install from GitHub
        url=$(curl -fsSL "https://api.github.com/repos/home-sweet-gnome/dash-to-panel/releases/latest" \
            | grep "browser_download_url.*zip" | head -1 | cut -d'"' -f4)
        curl -fsSL "$url" -o "$tmpdir/dash-to-panel.zip"
    }

    gnome-extensions install "$tmpdir/dash-to-panel.zip"
    rm -rf "$tmpdir"

    echo "Dash to Panel installed."
else
    echo "Dash to Panel is already installed."
fi

# Enable extension
if ! gnome-extensions show "$EXT_UUID" 2>/dev/null | grep -q "ENABLED"; then
    echo "Enabling Dash to Panel..."
    gnome-extensions enable "$EXT_UUID" 2>/dev/null || true
fi

# Apply saved config
# hash: {{ include "dot_config/dconf/dash-to-panel.dconf" | sha256sum }}
CONFIG="{{ .chezmoi.homeDir }}/.config/dconf/dash-to-panel.dconf"
if [ -f "$CONFIG" ]; then
    echo "Applying Dash to Panel config..."
    dconf load /org/gnome/shell/extensions/dash-to-panel/ < "$CONFIG"
    echo "Config applied."
fi
{{- end }}
