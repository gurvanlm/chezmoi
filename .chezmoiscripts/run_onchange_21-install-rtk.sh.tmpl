{{- if .installRtk -}}
#!/bin/bash
set -euo pipefail

if ! command -v rtk &> /dev/null; then
    echo "Installing rtk (Rust Token Killer)..."
    mkdir -p ~/.local/bin

    url=$(curl -fsSL "https://api.github.com/repos/rtk-ai/rtk/releases/latest" \
        | grep "browser_download_url.*rtk-x86_64-unknown-linux-musl.tar.gz\"" | head -1 | cut -d'"' -f4)

    tmpdir=$(mktemp -d)
    curl -fsSL "$url" | tar xz -C "$tmpdir"
    install -m 755 "$tmpdir/rtk" ~/.local/bin/rtk
    rm -rf "$tmpdir"

    echo "rtk installed."
else
    echo "rtk is already installed."
fi
{{- end }}
